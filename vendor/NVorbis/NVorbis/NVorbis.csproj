<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Maintained fork of NVorbis (https://github.com/NVorbis/NVorbis) v0.10.5.
    Originally by Andrew Ward (MIT, see ../LICENSE). The decoder logic is the
    upstream source; only the namespace/assembly were re-identified under
    MidiSharp.Audio.Vorbis so this fork can never collide with the upstream
    NVorbis package. Attribution: see THIRD-PARTY-NOTICES.md at the repo root.
  -->

  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <AssemblyName>MidiSharp.Audio.Vorbis</AssemblyName>
    <RootNamespace>MidiSharp.Audio.Vorbis</RootNamespace>
    <Nullable>disable</Nullable>
    <LangVersion>latest</LangVersion>
    <Description>Ogg Vorbis decoder — a maintained fork of NVorbis v0.10.5 (© Andrew Ward, MIT).</Description>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591;CS0618</NoWarn>
  </PropertyGroup>

</Project>
