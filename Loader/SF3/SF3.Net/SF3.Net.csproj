    <ItemGroup>
        <ProjectReference Include="..\..\SF2\SF2.Net\SF2.Net.csproj" />
        <ProjectReference Include="..\..\..\vendor\NVorbis\NVorbis\NVorbis.csproj" />
    </ItemGroup>

</Project>
